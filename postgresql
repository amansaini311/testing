-- Markers Table
CREATE TABLE IF NOT EXISTS markers (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    username VARCHAR(100) UNIQUE NOT NULL,
    full_name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    tickets_generated INT DEFAULT 0,
    tickets_approved INT DEFAULT 0,
    tickets_cleared INT DEFAULT 0,
    is_volunteer INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Volunteers Table
CREATE TABLE IF NOT EXISTS volunteers (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    username VARCHAR(100) UNIQUE NOT NULL,
    full_name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    tickets_claimed INT DEFAULT 0,
    tickets_closed INT DEFAULT 0,
    is_marker INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Authority Table
CREATE TABLE IF NOT EXISTS authority (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    username VARCHAR(100) UNIQUE NOT NULL,
    full_name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    tickets_approved INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tickets Table
CREATE TABLE IF NOT EXISTS tickets (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    ticket_generated_by UUID NOT NULL REFERENCES markers(id) ON DELETE CASCADE,
    ticket_approved_by UUID REFERENCES authority(id) ON DELETE SET NULL,
    ticket_claimed_by UUID REFERENCES volunteers(id) ON DELETE SET NULL,
    ticket_generation_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ticket_claim_time TIMESTAMP,
    ticket_cleared_time TIMESTAMP,
    status VARCHAR(50) DEFAULT 'Unclaimed' CHECK (status IN ('Unclaimed', 'In Progress', 'Cleared')),
    severity VARCHAR(50) NOT NULL CHECK (severity IN ('Low', 'Medium', 'High')),
    latitude DECIMAL(10, 8) NOT NULL,
    longitude DECIMAL(11, 8) NOT NULL,
    initial_photo_url VARCHAR(500) NOT NULL,
    cleared_photo_url VARCHAR(500),
    location_description VARCHAR(500),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create indexes for performance
CREATE INDEX IF NOT EXISTS idx_tickets_status ON tickets(status);
CREATE INDEX IF NOT EXISTS idx_tickets_severity ON tickets(severity);
CREATE INDEX IF NOT EXISTS idx_tickets_location ON tickets(latitude, longitude);
CREATE INDEX IF NOT EXISTS idx_tickets_generated_by ON tickets(ticket_generated_by);
CREATE INDEX IF NOT EXISTS idx_tickets_claimed_by ON tickets(ticket_claimed_by);
CREATE INDEX IF NOT EXISTS idx_markers_email ON markers(email);
CREATE INDEX IF NOT EXISTS idx_volunteers_email ON volunteers(email);
CREATE INDEX IF NOT EXISTS idx_authority_email ON authority(email);

-- Notifications Table
CREATE TABLE IF NOT EXISTS notifications (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    volunteer_id UUID NOT NULL REFERENCES volunteers(id) ON DELETE CASCADE,
    ticket_id UUID NOT NULL REFERENCES tickets(id) ON DELETE CASCADE,
    is_read BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IF NOT EXISTS idx_notifications_volunteer ON notifications(volunteer_id);
CREATE INDEX IF NOT EXISTS idx_notifications_unread ON notifications(volunteer_id, is_read);
